{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PandocFlow",
  "version": "2.0.0",
  "identifier": "com.leecaiy04.pandoc-flow",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pandoc Flow",
        "width": 450,
        "height": 450,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../templates/*",
      "../scripts/*",
      "../fonts/*"
    ],
    "category": "Productivity",
    "longDescription": "Converts Markdown to GB/T 9704-2012 Official Word Documents.",
    "shortDescription": "One-click Pandoc Document Converter"
  }
}
