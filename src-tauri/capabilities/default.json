{
  "$schema": "../gen/schemas/capability.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "dialog:default",
    {
      "identifier": "allow-convert-markdown",
      "allow": [
        "convert_markdown"
      ]
    }
  ]
}
