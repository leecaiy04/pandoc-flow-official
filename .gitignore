# 📋 Pandoc Flow Git Ignore

# 🛠️ 系统与编辑器
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
.obsidian/workspace.json

# 📤 转换输出 (忽略 output 目录下的内容，保留目录本身)
output/*
!output/.gitkeep

# 📝 临时与备份文件
*.backup
*.tmp
*.log
conf.user.json.backup
test_out.txt
test.docx
示例文档_测试.docx
榛戜綋涓夊彿
浠垮畫涓夊彿

# 📄 自动生成的 Word 文档 (可选，如果是转换后的文件)
*.docx
!templates/公文模板.docx
!templates/reference.docx
!docs/☆公文格式GB_T 9704—2012.pdf

# 📂 其他
node_modules/
.env
